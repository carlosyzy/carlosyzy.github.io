    textureasset: {
        title: 'TextureAsset 纹理资产',
        content: `
            <h1>TextureAsset 纹理资产</h1>
            
            <p>TextureAsset（纹理资产）用于存储纹理图像数据，包括宽度、高度、通道数、像素数据等信息。</p>

            <h2>头文件</h2>
            <pre><code>#include "core/asset/texture-asset.h"</code></pre>

            <h2>API 接口</h2>
            
            <h3>纹理创建</h3>
            <table>
                <thead>
                    <tr><th>接口</th><th>说明</th><th>参数</th><th>返回值</th></tr>
                </thead>
                <tbody>
                    <tr><td>create(width, height, channels, pixelsVector, format)</td><td>通过像素数据创建纹理</td><td>width, height, channels, pixelsVector, format</td><td>void</td></tr>
