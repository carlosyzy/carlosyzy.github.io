            <h3>纹理查询</h3>
            <table>
                <thead>
                    <tr><th>接口</th><th>说明</th><th>返回值</th></tr>
                </thead>
                <tbody>
                    <tr><td>getWidth()</td><td>获取纹理宽度</td><td>const int</td></tr>
                    <tr><td>getHeight()</td><td>获取纹理高度</td><td>const int</td></tr>
                    <tr><td>channels()</td><td>获取纹理通道数</td><td>int</td></tr>
                    <tr><td>getGfxTexture()</td><td>获取图形纹理</td><td>GfxTexture*</td></tr>
                </tbody>
            </table>
        `
    },
    gltfasset: {
        title: 'GLTFAsset GLTF资产',
        content: `
            <h1>GLTFAsset GLTF 资产</h1>
            
            <p>GLTFAsset（GLTF 资产）用于加载和解析 GLTF 格式的 3D 模型文件，将 GLTF 数据转换为引擎可用的 MeshAsset。</p>

            <h2>头文件</h2>
            <pre><code>#include "core/asset/gltf-asset.h"</code></pre>

            <h2>API 接口</h2>
            
            <h3>GLTF 解析</h3>
            <table>
                <thead>
                    <tr><th>接口</th><th>说明</th><th>参数</th><th>返回值</th></tr>
                </thead>
                <tbody>
                    <tr><td>create(m_asset)</td><td>解析 GLTF 数据</td><td>m_asset: fastgltf Asset 指针</td><td>void</td></tr>
                    <tr><td>getRoot()</td><td>获取 GLTF 根节点</td><td>-</td><td>const GLTFNode&</td></tr>
                    <tr><td>getMeshs()</td><td>获取所有网格资产</td><td>-</td><td>map&lt;string, MeshAsset*&gt;&</td></tr>
                    <tr><td>getMesh(meshName)</td><td>获取指定名称的网格资产</td><td>meshName: 网格名称</td><td>MeshAsset*</td></tr>
                </tbody>
            </table>
        `
    },
    alpha: {
        title: 'Alpha 启动场景',
        content: `
            <h1>Alpha 启动场景</h1>
            
            <p>Alpha（启动场景）是引擎启动时的过渡界面，不可取消，但可以自定义背景颜色、Logo 以及显示时间。</p>

            <h2>头文件</h2>
            <pre><code>#include "core/alpha/alpha.h"</code></pre>

            <h2>API 接口</h2>
            
            <h3>构造函数</h3>
            <table>
                <thead>
                    <tr><th>接口</th><th>说明</th></tr>
                </thead>
                <tbody>
                    <tr><td><code class="inline">Alpha(name, uuid = "")</code></td><td>创建启动场景</td></tr>
                </tbody>
            </table>

            <h3>生命周期</h3>
            <table>
                <thead>
                    <tr><th>接口</th><th>说明</th><th>参数</th><th>返回值</th></tr>
                </thead>
                <tbody>
                    <tr><td>update(deltaTime)</td><td>每帧更新</td><td>deltaTime: 时间增量</td><td>void</td></tr>
                    <tr><td>destroy()</td><td>销毁场景</td><td>-</td><td>void</td></tr>
                </tbody>
            </table>

            <h2>特性说明</h2>
            <ul>
                <li><strong>背景</strong>：启动画面背景图片</li>
                <li><strong>Logo</strong>：自定义 Logo 显示</li>
                <li><strong>显示时间</strong>：可配置 Logo 显示持续时间</li>
            </ul>
        `
    },
    multiplatform: {
        title: '多平台适配教程',
        content: `
            <h1>多平台适配教程</h1>
            
            <p>本教程介绍如何使用 Boo Engine 进行跨平台开发，支持 macOS 和 Windows 两个平台。</p>

            <h2>环境要求</h2>
            <table>
                <thead>
                    <tr><th>平台</th><th>必需工具</th></tr>
                </thead>
                <tbody>
                    <tr><td>macOS</td><td>CMake 3.15+、Xcode 命令行工具</td></tr>
                    <tr><td>Windows</td><td>CMake 3.15+、Visual Studio</td></tr>
                </tbody>
            </table>

            <h2>第一步：构建引擎</h2>
            <p>首先需要构建 Boo Engine 引擎库，请参考构建文档进行构建。</p>

            <h3>macOS 构建</h3>
            <pre><code># Debug 构建
cmake -B build -DCMAKE_BUILD_TYPE=Debug

# Release 构建
cmake -B build -DCMAKE_BUILD_TYPE=Release

# 构建项目
cmake --build build

# 安装到 dist 目录
cmake --install build --prefix ./dist</code></pre>

            <h3>Windows 构建</h3>
            <pre><code># 创建构建目录
cmake -S . -B build -G "Visual Studio 17 2022" -A x64

# Release 构建
cmake --build build --config Release

# 安装到 dist 目录
cmake --install build --prefix ./dist --config Release</code></pre>

            <h2>第二步：准备引擎目录</h2>
            <p>构建完成后，将 <code>dist/</code> 目录复制到项目根目录，建议重命名为 <code>engine/</code>：</p>
            <pre><code>your-project/
├── engine/              # 从 dist 复制，重命名
│   ├── include/
│   │   ├── engine/     # 引擎头文件
│   │   └── libs/       # 三方库头文件
│   └── libs/           # 预编译库
├── src/                # 你的源代码
├── assets/             # 资源文件
├── CMakeLists.txt     # CMake 配置
└── app.cpp            # 入口文件</code></pre>

            <h2>第三步：配置 CMake</h2>
            <p>参考 Boo-Engine-Bricked 项目的 CMakeLists.txt 配置：</p>

            <h3>基础配置</h3>
            <pre><code>cmake_minimum_required(VERSION 3.15)
project(YourProject)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

# 设置引擎目录
set(BOO_ENGINE_DIR \${CMAKE_CURRENT_SOURCE_DIR}/engine)
add_library(BooEngine STATIC IMPORTED)

# 平台相关的库文件
if(APPLE)
    set_target_properties(BooEngine PROPERTIES
        IMPORTED_LOCATION_DEBUG \${BOO_ENGINE_DIR}/libs/libBooEngined.a
        IMPORTED_LOCATION_RELEASE \${BOO_ENGINE_DIR}/libs/libBooEngine.a
    )
elseif(WIN32)
    set_target_properties(BooEngine PROPERTIES
        IMPORTED_LOCATION_DEBUG \${BOO_ENGINE_DIR}/libs/BooEngined.lib
        IMPORTED_LOCATION_RELEASE \${BOO_ENGINE_DIR}/libs/BooEngine.lib
    )
endif()</code></pre>

            <h3>头文件目录</h3>
            <pre><code>target_include_directories(BooEngine INTERFACE
    \${BOO_ENGINE_DIR}/include
    \${BOO_ENGINE_DIR}/include/libs/fastgltf
    \${BOO_ENGINE_DIR}/include/libs/freetype2
    \${BOO_ENGINE_DIR}/include/libs/glfw
    \${BOO_ENGINE_DIR}/include/libs/glslang
    \${BOO_ENGINE_DIR}/include/libs/nlohmann
    \${BOO_ENGINE_DIR}/include/libs/simdjson
    \${BOO_ENGINE_DIR}/include/libs/stb
    \${BOO_ENGINE_DIR}/include/libs/vulkan
    \${BOO_ENGINE_DIR}/include/libs/volk
)</code></pre>

            <h3>平台相关系统库</h3>
            <p><strong>macOS:</strong></p>
            <pre><code>if(APPLE)
    find_library(COCOA_LIBRARY     Cocoa      REQUIRED)
    find_library(FOUNDATION_LIBRARY Foundation REQUIRED)
    find_library(APPKIT_LIBRARY    AppKit     REQUIRED)
    find_library(IOKIT_LIBRARY     IOKit      REQUIRED)

    find_package(ZLIB  REQUIRED)
    find_package(BZip2 REQUIRED)
    find_package(PNG   REQUIRED)

    target_link_libraries(BooEngine INTERFACE
        ZLIB::ZLIB
        BZip2::BZip2
        PNG::PNG
        \${IOKIT_LIBRARY}
        \${COCOA_LIBRARY}
        \${FOUNDATION_LIBRARY}
        \${APPKIT_LIBRARY}
        \${BOO_ENGINE_DIR}/libs/freetype2/libfreetype.a
        \${BOO_ENGINE_DIR}/libs/glfw/libglfw3.a
        \${BOO_ENGINE_DIR}/libs/glslang/libglslang.a
        \${BOO_ENGINE_DIR}/libs/glslang/libglslang-default-resource-limits.a
        \${BOO_ENGINE_DIR}/libs/glslang/libSPIRV.a
        \${BOO_ENGINE_DIR}/libs/glslang/libSPIRV-Tools.a
        \${BOO_ENGINE_DIR}/libs/glslang/libSPIRV-Tools-opt.a
    )
endif()</code></pre>

            <p><strong>Windows:</strong></p>
            <pre><code>elseif(WIN32)
    target_link_libraries(BooEngine INTERFACE
        \${BOO_ENGINE_DIR}/libs/freetype2/freetype.lib
        \${BOO_ENGINE_DIR}/libs/glfw/lib-vc2022/glfw3_mt.lib
        # glslang
        debug \${BOO_ENGINE_DIR}/libs/glslang/glslangd.lib
        optimized \${BOO_ENGINE_DIR}/libs/glslang/glslang.lib
        debug \${BOO_ENGINE_DIR}/libs/glslang/glslang-default-resource-limitsd.lib
        optimized \${BOO_ENGINE_DIR}/libs/glslang/glslang-default-resource-limits.lib
        debug \${BOO_ENGINE_DIR}/libs/glslang/SPIRVd.lib
        optimized \${BOO_ENGINE_DIR}/libs/glslang/SPIRV.lib
        debug \${BOO_ENGINE_DIR}/libs/glslang/SPIRV-Toolsd.lib
        optimized \${BOO_ENGINE_DIR}/libs/glslang/SPIRV-Tools.lib
        debug \${BOO_ENGINE_DIR}/libs/glslang/SPIRV-Tools-optd.lib
        optimized \${BOO_ENGINE_DIR}/libs/glslang/SPIRV-Tools-opt.lib
    )
endif()

            <h2>第四步：创建可执行文件</h2>
            <pre><code># 收集源文件
file(GLOB_RECURSE PROJECT_SOURCES CONFIGURE_DEPENDS
    "src/*.cpp"
    "src/*.h"
    "src/*.hpp"
)

# 创建可执行文件
add_executable(
    \${PROJECT_NAME}
    \${PROJECT_SOURCES}
    app.cpp
)

# 链接引擎
target_link_libraries(\${PROJECT_NAME} PRIVATE BooEngine)
target_include_directories(\${PROJECT_NAME} PRIVATE
    \${CMAKE_CURRENT_SOURCE_DIR}/src
)</code></pre>

            <h2>第五步：资源复制</h2>
            <p>构建后需要将资源文件复制到输出目录：</p>
            <pre><code># 资源复制
if(APPLE)
    add_custom_command(TARGET \${PROJECT_NAME} POST_BUILD
        COMMAND \${CMAKE_COMMAND} -E rm -rf "$\$<TARGET_FILE_DIR:\${PROJECT_NAME}>/assets"
        COMMAND \${CMAKE_COMMAND} -E copy_directory "\${CMAKE_CURRENT_SOURCE_DIR}/assets" "$\$<TARGET_FILE_DIR:\${PROJECT_NAME}>/assets"
        COMMENT "复制 assets 到构建目录"
    )
elseif(WIN32)
    add_custom_command(TARGET \${PROJECT_NAME} POST_BUILD
        COMMAND \${CMAKE_COMMAND} -E rm -rf "$\$<TARGET_FILE_DIR:\${PROJECT_NAME}>/assets"
        COMMAND \${CMAKE_COMMAND} -E copy_directory "\${CMAKE_CURRENT_SOURCE_DIR}/assets" "$\$<TARGET_FILE_DIR:\${PROJECT_NAME}>/assets"
        COMMENT "复制 assets 到构建目录"
    )
    set_target_properties(\${PROJECT_NAME} PROPERTIES
        VS_DEBUGGER_WORKING_DIRECTORY "$\$<TARGET_FILE_DIR:\${PROJECT_NAME}>"
    )
endif()</code></code></pre>

            <h2>构建与运行</h2>

            <h3>macOS</h3>
            <pre><code># Debug
cmake -B build -DCMAKE_BUILD_TYPE=Debug
cmake --build build
./build/YourProject

# Release
cmake -B build -DCMAKE_BUILD_TYPE=Release
cmake --build build
./build/YourProject</code></pre>

            <h3>Windows</h3>
            <pre><code># 使用 Visual Studio 打开或命令行构建
cmake -S . -B build -G "Visual Studio 17 2022" -A x64
cmake --build build --config Release
.\\build\\Release\\YourProject.exe</code></pre>

            <h2>注意事项</h2>
            <ul>
                <li><strong>库文件命名</strong>：macOS 使用 <code>.a</code> 静态库，Windows 使用 <code>.lib</code></li>
                <li><strong>Debug/Release</strong>：Windows 需要根据配置选择对应的库文件（带 <code>d</code> 后缀的是 Debug 版本）</li>
                <li><strong>资源路径</strong>：确保 <code>assets</code> 目录在构建输出的可执行文件旁边</li>
                <li><strong>三方库头文件</strong>：构建时可以通过 <code>-DBOO_INSTALL_THIRDPARTY_HEADERS=OFF</code> 关闭三方头文件安装</li>
            </ul>
        `
    }
};

// 主应用类
class BooDocsApp {
    constructor() {
        this.searchInput = document.getElementById('searchInput');
        this.navMenu = document.getElementById('navMenu');
        this.contentArea = document.getElementById('contentArea');
        this.currentId = 'home';
        this.expandedGroups = new Set(['渲染组件', 'ui_render', '3d_render', '其他组件', '3d_other', 'tool_other']);
        
        this.init();
    }

    init() {
        this.renderNav();
        this.bindEvents();
        this.navigate('home');
    }

    // 渲染导航菜单
    renderNav() {
        let html = '';
        DOCS_DATA.forEach(group => {
            if (group.children) {
                const expandKey = group.expandId || group.title;
                const isExpanded = group.alwaysExpanded || this.expandedGroups.has(expandKey);
                html += `<div class="nav-group">
                    <div class="nav-group-title${group.alwaysExpanded ? '' : ' expandable'}" ${!group.alwaysExpanded ? `data-group="${expandKey}"` : ''}>
                        ${!group.alwaysExpanded ? `<svg class="expand-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            ${isExpanded ? '<path d="M6 9l6 6 6-6"/>' : '<path d="M9 6l6 6-6 6"/>'}
                        </svg>` : ''}
                        ${group.title}
                    </div>`;
                
                if (isExpanded) {
                    html += this.renderNestedGroup(group.children);
                }
                html += '</div>';
            } else {
                html += `<div class="nav-group">
                    <div class="nav-group-title">${group.title}</div>`;
            
                group.items.forEach(item => {
                    const isActive = item.id === this.currentId ? 'active' : '';
                    html += `<a class="nav-item ${isActive}" data-id="${item.id}">${item.name}</a>`;
                });
            
                html += '</div>';
            }
        });
        
        this.navMenu.innerHTML = html;
    }

    // 渲染嵌套组
    renderNestedGroup(children) {
        let html = '<div class="nav-nested">';
        
        children.forEach(child => {
            if (child.id) {
                const isActive = child.id === this.currentId ? 'active' : '';
                html += `<a class="nav-item ${isActive}" data-id="${child.id}">${child.name}</a>`;
            } else if (child.children) {
                const expandKey = child.expandId || child.title;
                const isExpanded = this.expandedGroups.has(expandKey);
                html += `<div class="nav-subgroup">
                    <div class="nav-subgroup-title expandable" data-group="${expandKey}">
                        <svg class="expand-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            ${isExpanded ? '<path d="M6 9l6 6 6-6"/>' : '<path d="M9 6l6 6-6 6"/>'}
                        </svg>
                        ${child.title}
                    </div>`;
                
                if (isExpanded) {
                    html += this.renderNestedGroup(child.children);
                }
                html += '</div>';
            } else if (child.items) {
                child.items.forEach(item => {
                    const isActive = item.id === this.currentId ? 'active' : '';
                    html += `<a class="nav-item nav-item-nested ${isActive}" data-id="${item.id}">${item.name}</a>`;
                });
            }
        });
        
        html += '</div>';
        return html;
    }

    // 绑定事件
    bindEvents() {
        // 导航点击
        this.navMenu.addEventListener('click', (e) => {
            const navItem = e.target.closest('.nav-item');
            if (navItem) {
                const id = navItem.dataset.id;
                this.navigate(id);
                return;
            }

            // 展开/收起点击
            const expandable = e.target.closest('.expandable');
            if (expandable) {
                const groupTitle = expandable.dataset.group;
                this.toggleExpand(groupTitle);
            }
        });

        // 搜索功能
        this.searchInput.addEventListener('input', (e) => {
            this.handleSearch(e.target.value);
        });
    }

    // 切换展开/收起
    toggleExpand(groupTitle) {
        if (this.expandedGroups.has(groupTitle)) {
            this.expandedGroups.delete(groupTitle);
        } else {
            this.expandedGroups.add(groupTitle);
        }
        this.renderNav();
    }

    // 导航到指定页面
    navigate(id) {
        this.currentId = id;
        
        // 更新导航状态
        document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.toggle('active', item.dataset.id === id);
        });

        // 渲染内容
        const doc = DOCS_CONTENT[id];
        if (doc) {
            this.contentArea.innerHTML = `<div class="content-card">${doc.content}</div>`;
        } else {
            this.contentArea.innerHTML = `<div class="content-card"><h1>页面未找到</h1><p>无法加载页面: ${id}</p></div>`;
        }

        // 清空搜索
        this.searchInput.value = '';
    }

    // 搜索功能
    handleSearch(query) {
        if (!query.trim()) {
            this.renderNav();
            return;
        }

        query = query.toLowerCase();
        let html = '';
        
        DOCS_DATA.forEach(group => {
            const matchedItems = group.items.filter(item => 
                item.name.toLowerCase().includes(query) || 
                item.id.toLowerCase().includes(query)
            );
            
            if (matchedItems.length > 0) {
                html += `<div class="nav-group">
                    <div class="nav-group-title">${group.title}</div>`;
                
                matchedItems.forEach(item => {
                    const isActive = item.id === this.currentId ? 'active' : '';
                    html += `<a class="nav-item ${isActive}" data-id="${item.id}">${item.name}</a>`;
                });
                
                html += '</div>';
            }
        });

        if (!html) {
            html = '<div style="padding: 20px; color: var(--text-muted); text-align: center;">未找到匹配的文档</div>';
        }

        this.navMenu.innerHTML = html;
    }
}

// 初始化应用
document.addEventListener('DOMContentLoaded', () => {
    window.app = new BooDocsApp();
});
