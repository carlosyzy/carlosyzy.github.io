                    <tr><td>setVertexShader(vert)</td><td>设置顶点着色器</td><td>vert: ShaderAsset 指针或路径</td><td>void</td></tr>
                    <tr><td>setFragmentShader(frag)</td><td>设置片段着色器</td><td>frag: ShaderAsset 指针或路径</td><td>void</td></tr>
